rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Cualquiera puede leer partidos
    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == "REEMPLAZAR_CON_ADMIN_UID";
    }

    // Usuarios: cualquiera puede leer, solo vos podés escribir tu propio perfil
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Predicciones: cualquiera puede leer, solo el dueño puede escribir
    match /predictions/{predId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}
