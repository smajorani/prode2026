rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == "K7owe52KlCS68DtzvJpm1N52ZA32";
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /predictions/{predId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Torneos: cualquier usuario logueado puede crear y leer
    // Solo miembros pueden actualizar (unirse)
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
      allow update: if request.auth != null && request.auth.uid in resource.data.members
                    || request.auth.uid == resource.data.createdBy;
    }
  }
}
